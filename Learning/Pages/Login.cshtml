@page
@model Learning.Pages.LoginModel
@{
    ViewData["Title"] = "Đăng nhập";
}

<div class="row justify-content-center mt-5">
    <div class="col-md-4 shadow p-4 rounded bg-white border border-primary">
        <h3 class="text-center text-primary mb-4">🔑 ĐĂNG NHẬP</h3>

        @if (!string.IsNullOrEmpty(Model.Message))
        {
            <div class="alert alert-danger">@Model.Message</div>
        }

        <form method="post">
            <div class="mb-3">
                <label>Tên đăng nhập</label>
                <input asp-for="Username" class="form-control" required />
            </div>
            <div class="mb-3">
                <label>Mật khẩu</label>
                <input asp-for="Password" type="password" class="form-control" required />
            </div>
            <button type="submit" class="btn btn-primary w-100 shadow-sm">Vào hệ thống</button>
        </form>

        <div class="text-center mt-3">
            <a asp-page="/Register" class="text-decoration-none">Chưa có tài khoản? Đăng ký ngay</a>
        </div>
    </div>
</div>