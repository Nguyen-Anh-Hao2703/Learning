@page
@model Learning.Pages.TestModel

<div id="question-container">
    <form method="post" asp-page-handler="Choice">
        <input type="hidden" name="path" value="@Model.url" />
        <input type="hidden" name="currentIndex" value="@Model.currentIndex" />
        <input type="hidden" name="currentPoint" value="@Model.currentPoint" />

        <p>
            @Model.Content_Test
            @if (!string.IsNullOrEmpty(Model.Picture))
            {
                <img src="data:image/png;base64,@Model.Picture" style="max-width:100%;" />
            }
        </p>

        <div id="answers-list">
            <input type="radio" asp-for="SelectedAnswer" id="A" value="A">
            <label for="A">@Model.Answer_A</label><br>

            <input type="radio" asp-for="SelectedAnswer" id="B" value="B">
            <label for="B">@Model.Answer_B</label><br>

            <input type="radio" asp-for="SelectedAnswer" id="C" value="C">
            <label for="C">@Model.Answer_C</label><br>

            <input type="radio" asp-for="SelectedAnswer" id="D" value="D">
            <label for="D">@Model.Answer_D</label>
        </div>

        <button type="submit" class="btn btn-primary mt-3">Câu tiếp theo</button>
    </form>
</div>