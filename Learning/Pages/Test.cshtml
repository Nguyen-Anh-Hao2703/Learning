@page
@model Learning.Pages.TestModel
@{
    ViewData["Title"] = "Làm bài thi";
}

<div class="container mt-5">
    <div class="card shadow-sm rounded-4 border-0">
        <div class="card-body p-4">
            @if (!string.IsNullOrEmpty(Model.Picture))
            {
                <div class="text-center mb-4">
                    <img src="data:image/png;base64,@Model.Picture" class="img-fluid rounded-3 shadow-sm" style="max-height: 300px;" />
                </div>
            }

            <h4 class="fw-bold mb-4">Câu @(Model.currentIndex + 1): @Model.Content_Test</h4>

            <form method="post" asp-page-handler="Choice">
                <input type="hidden" name="path" value="@Model.url" />
                <input type="hidden" name="currentIndex" value="@Model.currentIndex" />
                <input type="hidden" name="currentPoint" value="@Model.currentPoint" />
                <input type="hidden" name="correctText" value="@Model.current_Answer" />

                <div class="list-group">
                    @foreach (var item in Model.ShuffledAnswers)
                    {
                        <label class="list-group-item list-group-item-action d-flex align-items-center py-3">
                            <input class="form-check-input me-3" type="radio" asp-for="SelectedAnswer" value="@item.Value" required>
                            <span>@item.Value</span>
                        </label>
                    }
                </div>

                <div class="mt-4 text-end">
                    <button type="submit" class="btn btn-success btn-lg px-5 shadow-sm">Câu tiếp theo</button>
                </div>
            </form>
        </div>
    </div>
</div>