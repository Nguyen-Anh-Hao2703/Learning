<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Learning</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/Learning.styles.css" asp-append-version="true" />
</head>
<body>
    <header class="green_layout shadow-sm">
        <nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-light box-shadow mb-3">
            <a class="navbar-brand" href="/">
                <img src="~/Logo.png"
                     alt="Logo Trường"
                     style="width:200px; height:auto; border-radius: 10px;" />
            </a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1">
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-area="" asp-page="/Index">Trang chủ</a>
                        </li>
                        
                        <li class="nav-item">
                            @if (User.Identity?.IsAuthenticated == true)
                            {
                                <li class="nav-item">
                                    <a class="nav-link text-dark" asp-area="" asp-page="/EditProfile">Chỉnh sửa hồ sơ</a>
                                </li>
                                @* 1. Thẻ link hiển thị cho người dùng *@
                                <a class="nav-link text-dark" style="cursor:pointer;"
                                   onclick="arguments[0].preventDefault(); document.getElementById('logout-form').submit();">
                                   Đăng xuất (@User.Identity.Name)
                                </a>

                                @* 2. Form ẩn thực hiện lệnh POST bảo mật *@
                                <form id="logout-form" method="post" asp-page="/Logout" style="display:none;">
                                    @* ASP.NET sẽ tự chèn Antiforgery Token vào đây *@
                                </form>
                            }
                        </li>
                    </ul>
                </div>
        </nav>
    </header>
    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted">
        <div class="container">
            &copy; 2026 - Learning - Nguyễn Anh Hào
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
