@page
@model IndexModel
@{
    ViewData["Title"] = "Trang chủ";
}

<div class="container mt-5">
    @if (User.Identity!.IsAuthenticated)
    {
        <div class="text-center mb-5">
            <h1 class="display-4">Chào @User.Identity.Name!</h1>
            <p class="lead">Hệ thống học tập: <b>@Model.NameSchool</b> - Lớp: <b>@Model.NameClass</b></p>
        </div>

        @if (Model.CurrentUserRole == "Teacher")
        {
            <div class="admin-panel bg-light p-4 mb-5 border-start border-primary border-4 shadow-sm">
                <h5 class="mb-3">🛠️ Công cụ quản lý Môn học</h5>
                <form method="post" asp-page-handler="CreateFolder" class="row g-2">
                    <div class="col-md-9">
                        <input type="text" name="SubjectID" placeholder="Nhập Mã Môn học..." class="form-control" required />
                    </div>
                    <div class="col-md-3">
                        <button type="submit" class="btn btn-primary w-100">➕ Tạo môn học</button>
                    </div>
                </form>
            </div>
        }

        @* PHẦN HIỂN THỊ CHUNG *@
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h4>📚 Danh sách bài tập hiện có</h4>

            <form method="post" asp-page-handler="FindFolder" class="d-flex gap-2">
                <input type="text" name="SubjectID" value="@Model.Subject" placeholder="Lọc theo môn..." class="form-control form-control-sm" />
                <button type="submit" class="btn btn-sm btn-outline-primary">🔍</button>
                @if (!string.IsNullOrEmpty(Model.Subject))
                {
                    <a href="/Index" class="btn btn-sm btn-outline-secondary">Xóa</a>
                }
            </form>
        </div>

        <div class="row">
            @if (Model.StudentLessons.Any())
            {
                @foreach (var lesson in Model.StudentLessons)
                {
                    <div class="col-md-4 mb-3">
                        <div class="card shadow-sm h-100">
                            <div class="card-body">
                                <h5 class="card-title">📖 @lesson.Subject</h5>
                                <p class="card-text text-muted small">Giáo viên: @lesson.Teacher</p>
                                <a asp-page="/Class"
                                   asp-route-sName="@Model.NameSchool"
                                   asp-route-cName="@Model.NameClass"
                                   asp-route-subID="@lesson.Subject"
                                   asp-route-tID="@lesson.Teacher"
                                   class="btn btn-sm btn-success w-100">Vào học</a>
                            </div>
                        </div>
                    </div>
                }
            }
            else
            {
                <div class="col-12">
                    <div class="alert alert-warning text-center">
                        Chưa có dữ liệu nào cho lớp @Model.NameClass của bạn.
                    </div>
                </div>
            }
        </div>
    }
    else
    {
        <div class="text-center py-5">
            <h1 class="display-3 fw-bold text-primary">Learning</h1>
            <p class="lead">Vui lòng đăng nhập để truy cập tài liệu học tập.</p>
            <a href="/Login" class="btn btn-primary btn-lg px-5">Đăng nhập ngay</a>
        </div>
    }
</div>