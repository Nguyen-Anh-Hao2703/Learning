@page
@model ClassModel
@{
    ViewData["Title"] = "Chi tiết lớp học";
}

<div class="container mt-4">
    @* --- THÔNG BÁO --- *@
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show shadow-sm">
            @TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }
    @if (TempData["Message"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show shadow-sm">
            @TempData["Message"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    @* --- BREADCRUMB --- *@
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb shadow-sm p-2 bg-light rounded">
            <li class="breadcrumb-item"><a href="/Index" class="text-decoration-none">🏠 Trang chủ</a></li>
            <li class="breadcrumb-item active">@Model.sName</li>
            <li class="breadcrumb-item active" aria-current="page">Lớp @Model.cName</li>
        </ol>
    </nav>

    @* --- HEADER --- *@
    <div class="d-flex justify-content-between align-items-center mb-4 bg-white p-3 rounded shadow-sm border-bottom border-primary border-3">
        <div style="cursor: default; user-select: none;">
            <h2 class="text-primary mb-0">📖 Môn học: @Model.subID</h2>
            <small class="text-muted">Trường: @Model.sName | Lớp: @Model.cName</small>
        </div>
        <div class="text-end">
            <span class="badge bg-info text-dark fs-6">🍎 GV: @Model.tID</span>
        </div>
    </div>

    @* --- PHẦN DÀNH CHO GIÁO VIÊN --- *@
    @if (Model.CurrentUserRole == "Teacher")
    {
        <div class="upload-section bg-light p-4 mb-4 border-start border-primary border-4 shadow-sm">
            <h5 class="mb-3 text-primary">📤 Tải lên tài liệu mới</h5>
            <form method="post" enctype="multipart/form-data" asp-page-handler="UploadFile">
                @* Giữ lại dữ liệu URL cho lệnh POST *@
                <input type="hidden" name="sName" value="@Model.sName" />
                <input type="hidden" name="cName" value="@Model.cName" />
                <input type="hidden" name="subID" value="@Model.subID" />
                <input type="hidden" name="tID" value="@Model.tID" />

                <div class="input-group">
                    <input type="file" name="UploadFiles" class="form-control"
                           accept=".qs, .pdf, .docx, .pptx, .txt, .mp4, .zip, .mp3, .jpg, .png" required multiple />
                    <button type="submit" class="btn btn-primary px-4">⬆Tải lên</button>
                </div>
                <div class="mt-2" style="cursor: default; user-select: none;">
                    <small class="text-danger fw-bold">⚠Lưu ý:</small>
                    <small class="text-muted">Hệ thống tự động xử lý tên file không dấu để tránh lỗi.</small>
                </div>
            </form>
        </div>
    }

    <hr />

    @* --- DANH SÁCH FILE --- *@
    <h5 class="mb-3" style="cursor: default; user-select: none;">📂 Tài liệu học tập</h5>
    <div class="row">
        @if (Model.Files != null && Model.Files.Any())
        {
            @foreach (var file in Model.Files)
            {
                <div class="col-12 mb-2">
                    <div class="card card-body shadow-sm d-flex flex-row justify-content-between align-items-center py-2">
                        <div class="d-flex align-items-center" style="cursor: default;">
                            <span class="fs-4 me-3">📄</span>
                            <div>
                                <span class="fw-bold d-block">@file</span>
                                @if (file.EndsWith(".qs"))
                                {
                                    <span class="badge bg-warning text-dark" style="font-size: 0.7rem;">Yêu cầu Learning Player</span>
                                }
                            </div>
                        </div>

                        <div class="d-flex align-items-center gap-2">
                            <a href="@Model.GetFileUrl(file)" target="_blank" download="@file" class="btn btn-success btn-sm px-3 shadow-sm">
                                📥 Tải xuống
                            </a>

                            @if (file.EndsWith(".qs"))
                            {
                                <a href="/Test?path=@(System.Net.WebUtility.UrlEncode(Model.GetFileUrl(file)))&index=0"
                                   class="btn btn-primary btn-sm px-3 shadow-sm">
                                    📚 Làm bài tập
                                </a>
                            }

                            @if (Model.CurrentUserRole == "Teacher")
                            {
                                <a asp-page="/Dashboard"
                                   asp-route-filterClass="@Model.cName"
                                   asp-route-filterTest="@file"
                                   class="btn btn-info btn-sm px-3 shadow-sm">
                                    📊 Xem điểm
                                </a>

                                <form method="post" asp-page-handler="DeletedFile" asp-route-file="@file" class="d-inline">
                                    <input type="hidden" name="sName" value="@Model.sName" />
                                    <input type="hidden" name="cName" value="@Model.cName" />
                                    <input type="hidden" name="subID" value="@Model.subID" />
                                    <input type="hidden" name="tID" value="@Model.tID" />
                                    <button type="submit" class="btn btn-danger btn-sm shadow-sm"
                                            onclick="return confirm('Xóa vĩnh viễn bài này?')">
                                        🗑️ Xóa
                                    </button>
                                </form>
                            }
                        </div>
                    </div>
                </div>
            }
        }
        else
        {
            <div class="col-12 text-center py-5">
                <div class="text-muted" style="cursor: default; user-select: none;">
                    <i class="fs-1 d-block mb-3">📁</i>
                    <p>Thư mục này hiện đang trống.</p>
                </div>
            </div>
        }
    </div>

    @* --- FOOTER TRANG --- *@
    <div class="mt-5 p-3 bg-dark text-white rounded shadow text-center" style="cursor: default; user-select: none;">
        <h6>Ứng dụng hỗ trợ học tập</h6>
        <p class="small opacity-75">Để chạy các file <b>.qs</b>, hãy cài đặt <b>Learning Student</b>.</p>
        <a href="~/Learning Student Setup.exe" class="btn btn-light btn-sm fw-bold">⬇️ Tải Learning Student</a>
    </div>

    <div class="mt-4 mb-5">
        <a href="/Index" class="btn btn-outline-secondary px-4">⬅️ Quay lại</a>
    </div>
</div>

@functions {
    bool IsImage(string fileName)
    {
        string ext = System.IO.Path.GetExtension(fileName).ToLower();
        return new[] { ".jpg", ".png", ".jpeg", ".gif" }.Contains(ext);
    }
}