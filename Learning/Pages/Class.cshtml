@page
@model ClassModel
@{
    ViewData["Title"] = "Chi tiết lớp học";
}

<div class="container mt-4">
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a href="/Index">Trang chủ</a></li>
            <li class="breadcrumb-item active">@Model.sName</li>
            <li class="breadcrumb-item active" aria-current="page">Lớp @Model.cName</li>
        </ol>
    </nav>

    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2>📚 Môn học: @Model.subID</h2>
            <p class="text-muted">Lớp: @Model.cName - @Model.sName</p>
        </div>
        <span class="badge bg-info text-dark p-2">🍎 Giáo viên: @Model.tID</span>
    </div>

    @if (Model.CurrentUserRole == "Teacher")
    {
        <div class="upload-section bg-light p-4 mb-4 border-start border-primary border-4 shadow-sm">
            <h5 class="mb-3">📤 Quản lý tài liệu bài học</h5>
            <form method="post" enctype="multipart/form-data" asp-page-handler="UploadFile">
                <input type="hidden" name="sName" value="@Model.sName" />
                <input type="hidden" name="cName" value="@Model.cName" />
                <input type="hidden" name="subID" value="@Model.subID" />
                <input type="hidden" name="tID" value="@Model.tID" />

                <div class="input-group">
                    <input type="file" name="UploadFiles" class="form-control"
                           accept=".qs, .slq, .pdf, .docx, .pptx, .mp4, .zip, .mp3, .jpg, .png" required multiple />
                    <button type="submit" class="btn btn-primary">➕ Tải lên</button>
                </div>
                <div class="mt-2">
                    <small class="text-danger fw-bold">Lưu ý:</small>
                    <small class="text-muted">Hỗ trợ file bài tập .qs và các định dạng tài liệu phổ biến.</small>
                </div>
            </form>

            <div class="mt-3 p-2 border-top">
                <small>Chưa có công cụ soạn bài (.qs)?</small>
                <a href="~/Learning_Setup.exe" class="btn btn-sm btn-outline-dark ms-2">⬇️ Tải Learning Setup</a>
            </div>
        </div>
    }

    <hr />

    <h5 class="mb-3">📂 Danh sách tài liệu bài học</h5>
    <div class="row">
        @if (Model.Files != null && Model.Files.Any())
        {
            @foreach (var file in Model.Files)
            {
                <div class="col-12 mb-2">
                    <div class="list-group-item d-flex justify-content-between align-items-center shadow-sm">
                        <div>
                            <span class="fs-5">📄 @file</span>
                        </div>
                        <div class="d-flex gap-2 align-items-center">
                            @if (file.EndsWith(".slq") || file.EndsWith(".qs"))
                            {
                                <span class="badge bg-warning text-dark small">Yêu cầu Learning App</span>
                            }
                            @* Link tải trực tiếp từ Supabase thông qua hàm GetFileUrl *@
                            <a href="@Model.GetFileUrl(file)" target="_blank" download="@file" class="btn btn-success btn-sm">
                                📥 Tải về
                            </a>
                        </div>
                    </div>
                </div>
            }
        }
        else
        {
            <div class="col-12 text-center py-5 text-muted">
                <p>Chưa có tài liệu nào được tải lên cho mục này.</p>
            </div>
        }
    </div>

    <div class="mt-5 border-top pt-3 text-center">
        <p class="small text-muted">Bạn cần ứng dụng <b>Learning Student</b> để chạy định dạng <b>.slq</b></p>
        <a href="~/Learning_Student.exe" class="btn btn-outline-primary btn-sm">⬇️ Tải Learning Student Player</a>
    </div>

    <div class="mt-4">
        <a href="/Index" class="btn btn-secondary px-4">⬅️ Quay lại trang chủ</a>
    </div>
</div>