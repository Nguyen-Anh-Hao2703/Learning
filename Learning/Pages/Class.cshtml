@page
@model ClassModel
@{
    ViewData["Title"] = "Chi tiết lớp học";
}

<div class="container mt-4">
    @* --- THÔNG BÁO --- *@
    @if (TempData["Error"] != null || TempData["Message"] != null)
    {
        <div class="alert @(TempData["Error"] != null ? "alert-danger" : "alert-success") alert-dismissible fade show shadow-sm">
            @(TempData["Error"] ?? TempData["Message"])
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    @* --- BREADCRUMB --- *@
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb shadow-sm p-3 bg-white rounded border">
            <li class="breadcrumb-item"><a href="/Index" class="text-decoration-none">🏠 Trang chủ</a></li>
            <li class="breadcrumb-item active">@Model.sName</li>
            <li class="breadcrumb-item active" aria-current="page">Lớp @Model.cName</li>
        </ol>
    </nav>

    @* --- HEADER --- *@
    <div class="d-flex justify-content-between align-items-center mb-4 bg-white p-4 rounded shadow-sm border-start border-primary border-5">
        <div>
            <h2 class="text-primary fw-bold mb-0">📖 @Model.subID</h2>
            <p class="text-muted mb-0 small">@Model.sName • Lớp @Model.cName</p>
        </div>
        <div class="text-end">
            <span class="badge rounded-pill bg-primary px-3 py-2">🍎 GV: @Model.tID</span>
        </div>
    </div>

    @* --- PHẦN DÀNH CHO GIÁO VIÊN --- *@
    @if (Model.CurrentUserRole == "Teacher")
    {
        <div class="card border-0 shadow-sm mb-4" style="background-color: #f8f9fa;">
            <div class="card-body p-4">
                <h5 class="mb-3 text-primary fw-bold"><i class="bi bi-cloud-arrow-up-fill me-2"></i>Tải lên tài liệu mới</h5>
                <form method="post" enctype="multipart/form-data" asp-page-handler="UploadFile">
                    <input type="hidden" name="sName" value="@Model.sName" />
                    <input type="hidden" name="cName" value="@Model.cName" />
                    <input type="hidden" name="subID" value="@Model.subID" />
                    <input type="hidden" name="tID" value="@Model.tID" />

                    <div class="input-group mb-2">
                        <input type="file" name="UploadFiles" class="form-control shadow-none" required multiple />
                        <button type="submit" class="btn btn-primary px-4 fw-bold">⬆ Tải lên</button>
                    </div>
                    <small class="text-muted italic">Chấp nhận: .qs, .pdf, .exe, .docx, .pptx, .mp4, .zip</small>
                </form>
            </div>
        </div>
    }

    @* --- DANH SÁCH FILE --- *@
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h5 class="fw-bold"><i class="bi bi-folder2-open me-2"></i>Tài liệu học tập</h5>
        <span class="badge bg-secondary">@(Model.Files?.Count() ?? 0) files</span>
    </div>

    <div class="row">
        @if (Model.Files != null && Model.Files.Any())
        {
            @foreach (var file in Model.Files)
            {
                <div class="col-12 mb-3">
                    <div class="card exam-card border-0 shadow-sm">
                        <div class="card-body d-flex align-items-center justify-content-between p-3">

                            <div class="d-flex align-items-center flex-grow-1">
                                <div class="file-icon me-3 text-primary fs-2">
                                    @if (file.EndsWith(".qs"))
                                    {
                                        <span>📝</span>
                                    }
                                    else if (IsImage(file))
                                    {

                                        <span>🖼️</span>
                                    }
                                    else
                                    {

                                        <span>📄</span>
                                    }
                                </div>
                                <div class="overflow-hidden">
                                    <span class="fw-bold d-block text-truncate" style="max-width: 400px;">@file</span>
                                    @if (file.EndsWith(".qs"))
                                    {
                                        <span class="badge bg-warning text-dark small" style="font-size: 0.65rem;">Learning Player Required</span>
                                    }
                                </div>
                            </div>

                            <div class="d-flex gap-2 align-items-center">
                                <a href="@Model.GetFileUrl(file)" target="_blank" download="@file"
                                   class="btn btn-outline-success btn-sm fw-bold">📥 Tải về</a>

                                @if (file.EndsWith(".qs"))
                                {
                                    <a href="/Test?path=@(System.Net.WebUtility.UrlEncode(Model.GetFileUrl(file)))&index=0&point=0"
                                       class="btn btn-start btn-sm px-3 fw-bold shadow-sm">📚 Làm bài</a>
                                }

                                @if (Model.CurrentUserRole == "Teacher")
                                {
                                    <div class="vr mx-2"></div> @* Vạch chia giữa học sinh và GV *@
                                    <a asp-page="/Dashboard" asp-route-filterClass="@Model.cName" asp-route-filterTest="@file"
                                       class="btn btn-outline-info btn-sm">📊 Điểm</a>

                                    <form method="post" asp-page-handler="DeletedFile" asp-route-file="@file" class="d-inline">
                                        <input type="hidden" name="sName" value="@Model.sName" />
                                        <input type="hidden" name="cName" value="@Model.cName" />
                                        <input type="hidden" name="subID" value="@Model.subID" />
                                        <input type="hidden" name="tID" value="@Model.tID" />
                                        <button type="submit" class="btn btn-light text-danger btn-sm border"
                                                onclick="return confirm('Xóa vĩnh viễn file này?')">
                                            🗑️
                                        </button>
                                    </form>
                                }
                            </div>

                        </div>
                    </div>
                </div>
            }
        }
        else
        {
            <div class="col-12 text-center py-5 bg-white rounded shadow-sm border">
                <i class="bi bi-folder-x fs-1 text-muted"></i>
                <p class="text-muted mt-2">Chưa có tài liệu nào được tải lên.</p>
            </div>
        }
    </div>

    @* --- FOOTER TOOLS --- *@
    <div class="row mt-5 g-3">
        <div class="col-md-6">
            <div class="p-4 bg-dark text-white rounded-4 shadow h-100 text-center">
                <h6>Học sinh</h6>
                <p class="small opacity-75">Cần phần mềm để làm bài tập .qs?</p>
                <a href="~/Learning Student Setup.exe" class="btn btn-light btn-sm fw-bold rounded-pill px-4">⬇ Tải Learning Student</a>
            </div>
        </div>
        @if (Model.CurrentUserRole == "Teacher")
        {
            <div class="col-md-6">
                <div class="p-4 bg-dark text-white rounded-4 shadow h-100 text-center border-start border-primary border-4">
                    <h6>Giáo viên</h6>
                    <p class="small opacity-75">Công cụ tạo bài tập .slq, .qs</p>
                    <a href="~/Learning Setup.exe" class="btn btn-light btn-sm fw-bold rounded-pill px-4">⬇ Tải Learning Creator</a>
                </div>
            </div>
        }
    </div>

    <div class="mt-5 mb-5">
        <a href="/Index" class="btn btn-link text-decoration-none text-secondary"><i class="bi bi-arrow-left"></i> Quay lại trang chủ</a>
    </div>
</div>

@functions {
    bool IsImage(string fileName)
    {
        string ext = System.IO.Path.GetExtension(fileName).ToLower();
        return new[] { ".jpg", ".png", ".jpeg", ".gif" }.Contains(ext);
    }
}