@page "{filterClass}/{filterTest}"
@model DashboardModel
@{
    ViewData["Title"] = "Danh sách";
}
<div class="display-1">
    <h2 class="text-center mb-4">DANH SÁCH ĐIỂM HỌC SINH</h2>
    <form method="get" class="row g-3 mb-4">
        <div class="col-md-4">
            <input type="text" name="filterClass" value="@Model.FilterClass" class="form-control" placeholder="Lớp...">
        </div>
        <div class="col-md-4">
            <input type="text" name="filterTest" value="@Model.FilterTest" class="form-control" placeholder="Tên bài tập...">
        </div>
        <div class="col-md-4">
            <button type="submit" class="btn btn-primary">Lọc</button>
        </div>
    </form>
    <div class="table-responsive">
        <table class="table table-bordered table-striped text-center">
            <thead class="table-dark">
                <tr>
                    <th style="width: 25%;">Họ và Tên</th>
                    <th style="width: 15%;">Lớp</th>
                    <th style="width: 30%;">Bài Kiểm Tra</th>
                    <th style="width: 15%;">Điểm</th>
                    <th style="width: 15%;">Ngày Làm</th>
                </tr>
            </thead>
            <tbody>
                @if (Model.ListResults != null && Model.ListResults.Any())
                {
                    foreach (var item in Model.ListResults)
                    {
                        <tr>
                            <td class="align-middle">@item.StudentName</td>
                            <td class="align-middle">@item.ClassName</td>
                            <td class="align-middle">@item.TestName</td>
                            <td class="align-middle fw-bold text-primary">@item.Point</td>
                            <td class="align-middle">@item.CreatedAt.ToString("dd/MM/yyyy")</td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="5" class="text-muted">Không tìm thấy dữ liệu kết quả nào.</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
